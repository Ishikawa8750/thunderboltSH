{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenBolt",
  "version": "0.1.0",
  "identifier": "dev.openbolt.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenBolt",
        "width": 1320,
        "height": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "entitlements": "openbolt.entitlements",
      "minimumSystemVersion": "11.0",
      "frameworks": [],
      "infoPlist": "mac-info.plist"
    },
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    }
  }
}
